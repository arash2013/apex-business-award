# ─── Brand ────────────────────────────────────────────────────────────────────
BRAND_NAME="Apex Business Award"
BRAND_SHORT="Apex"
BRAND_TAGLINE="Recognizing Excellence in Local Business"
BRAND_CITY="Houston"
BRAND_STATE="TX"
BRAND_YEAR="2026"

# ─── External APIs ────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
SERPAPI_KEY=
YELP_API_KEY=
BRIGHTDATA_PROXY_URL=

# ─── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=awards@apexbusinessaward.com
SENDGRID_FROM_NAME="Apex Business Award"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# ─── Infrastructure ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://apex:apex@localhost:5432/apex_dev
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development

# ─── Backend auth ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Azure AD admin protection (production)
# Register an app in Azure AD, define an "Apex.Admin" app role, assign it to admins.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_ADMIN_ROLE=Apex.Admin

# Dev-only API key fallback (used when AZURE_TENANT_ID / AZURE_CLIENT_ID are unset)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BRAND_NAME="Apex Business Award"
NEXT_PUBLIC_BRAND_SHORT="Apex"
NEXT_PUBLIC_BRAND_TAGLINE="Recognizing Excellence in Local Business"
NEXT_PUBLIC_BRAND_CITY="Houston"
NEXT_PUBLIC_BRAND_YEAR="2026"
NEXT_PUBLIC_BRAND_COLOR_PRIMARY="#1B2B4B"
NEXT_PUBLIC_BRAND_COLOR_ACCENT="#C9A84C"

# NextAuth (frontend — same Azure AD app registration)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_ADMIN_ROLE=Apex.Admin
